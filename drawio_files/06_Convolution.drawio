        <mxCell id="0CHwqjQtyf-E9pmUUxG1-11" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=17;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);" value="$$ 0 &amp;lt; t &amp;lt; 1 $$" vertex="1">
