        <mxCell id="pVaXnTPc6EFJBGHqVh7o-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=17;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);" value="$$ y(t) = \int_{3}^{t} 1 \cdot e^{-3 \cdot (t - \tau)} \space d \tau = e^{-3 \space t}&amp;nbsp;&amp;nbsp;\int_{3}^{t} e^{3 \space \tau} \space d \tau \space \Rightarrow \\ \\ y(t) =&amp;nbsp; \frac{1}{3} \space e^{-3 \space t}&amp;nbsp;&amp;nbsp;\big[ e^{3 \space \tau} \big]_{3}^{t}&amp;nbsp; =&amp;nbsp; \frac{1}{3} \space e^{-3 \space t} \big[ e^{3\space t} - e^{3 \cdot 3} \big]&amp;nbsp; \space \Rightarrow \\ \\ y(t) = \frac{1}{3} \space e^{-3 \space t} \cdot e^{3 \space t} -&amp;nbsp;&amp;nbsp;\frac{1}{3} \space e^{-3 \space t} \cdot e^9&amp;nbsp; = \frac{1}{3} \space e^0&amp;nbsp; \space - \frac{1}{3} e^{-3 \cdot (t -3)} \space \Rightarrow \\ \\ y(t) = \frac{1}{3} \cdot \Big[1 - e^{-3 \cdot (t -3)} \Big]&amp;nbsp;$$&amp;nbsp;" vertex="1">
