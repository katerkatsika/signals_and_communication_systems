        <mxCell id="U6G2szwLAGAI5TAP4TkU-51" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=17;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);" value="$$ y(t) = \int_{t -1}^{1} 1 \cdot (1 - t + \tau) \space d \tau = \int_{t -1}^{1}&amp;nbsp;(1 - t ) \space d \tau&amp;nbsp; + \int_{t -1}^{1}&amp;nbsp;\tau \space d \tau&amp;nbsp; = (1 - t ) \space&amp;nbsp;\int_{t -1}^{1}&amp;nbsp; d \tau&amp;nbsp; +&amp;nbsp;&amp;nbsp;\int_{t -1}^{1}&amp;nbsp;\tau \space d \tau \space&amp;nbsp;&amp;nbsp;\Rightarrow \\ \\&amp;nbsp; y(t) =&amp;nbsp;(1 - t) \space \big[ \tau \big]_{t - 1}^{1} + \frac{1}{2}&amp;nbsp; \big[ \tau^2 \big]_{t -1}^{1}&amp;nbsp; \space&amp;nbsp;&amp;nbsp;\Rightarrow \\ \\&amp;nbsp; y(t) = (1 - t) \cdot \big[1 - (t - 1) \big]&amp;nbsp; + \frac{1}{2} \big[ 1^2&amp;nbsp; - (t -1)^2 \big]&amp;nbsp; \space&amp;nbsp;&amp;nbsp;\Rightarrow \space y(t) =&amp;nbsp; (1 - t) \cdot (2 - t)&amp;nbsp;+ \frac{1}{2} \cdot \big[&amp;nbsp; 1 - (t^2 - 2 \cdot t + 1) \big]&amp;nbsp;&amp;nbsp; $$" vertex="1">
          <mxGeometry height="193.86" width="786.36" x="1055.75" y="1422.45" as="geometry" />
        </mxCell>
        <mxCell id="U6G2szwLAGAI5TAP4TkU-52" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=17;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);" value="$$ y(t) = 2 - t - 2 \cdot t + t^2 + \frac{1}{2} \cdot \left(&amp;nbsp; - t^2 + 2 \cdot t&amp;nbsp; \right) =&amp;nbsp; 2 - 3 \cdot t + t^2 -&amp;nbsp; \frac{t^2}{2} + t&amp;nbsp; \Rightarrow \\ \\&amp;nbsp;&amp;nbsp;&amp;nbsp;y(t) =&amp;nbsp; 2 -2 \cdot t +&amp;nbsp;&amp;nbsp;\frac{t^2}{2} $$" vertex="1">
