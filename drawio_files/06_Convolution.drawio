        <mxCell id="80Egrn9oX6l6pu--oT2R-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=17;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);" value="$$ y(t) = \int_{0}^{t} 1 \cdot (1 - t + \tau) \space d \tau = \int_{0}^{t} (1 - t ) \space d \tau&amp;nbsp; + \int_{0}^{t} \tau \space d \tau&amp;nbsp; = (1 - t ) \space&amp;nbsp;\int_{0}^{t}&amp;nbsp; d \tau&amp;nbsp; +&amp;nbsp;&amp;nbsp;\int_{0}^{t} \tau \space d \tau \space&amp;nbsp;&amp;nbsp;\Rightarrow \\ \\&amp;nbsp; y(t) =&amp;nbsp;(1 - t) \space \big[ \tau \big]_{0}^{t} + \frac{1}{2}&amp;nbsp; \big[ \tau^2 \big]_{0}^{t}&amp;nbsp; \space&amp;nbsp;&amp;nbsp;\Rightarrow \\ \\&amp;nbsp; y(t) = (1 - t) \cdot (t - 0)&amp;nbsp; + \frac{1}{2} \left( t^2&amp;nbsp; - 0^2 \right)&amp;nbsp; \space&amp;nbsp;&amp;nbsp;\Rightarrow \space y(t) =&amp;nbsp; t - t^2 + \frac{t^2}{2} \space&amp;nbsp;&amp;nbsp;\Rightarrow \\ \\ y(t) = t -&amp;nbsp;&amp;nbsp;\frac{t^2}{2}&amp;nbsp;$$" vertex="1">
          <mxGeometry height="259.51" width="638.53" x="881.28" y="1102.33" as="geometry" />
        </mxCell>
        <mxCell id="80Egrn9oX6l6pu--oT2R-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFFFFF);" value="$$ g(t) = - t + 1 $$" vertex="1">
          <mxGeometry height="20" width="100" x="1269.3700000000001" y="532" as="geometry" />
        </mxCell>
        <mxCell id="80Egrn9oX6l6pu--oT2R-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFFFFF);" value="$$ g(t - \tau) = - (t - \tau) + 1 \Rightarrow \\&amp;nbsp; \\ g(t - \tau) =&amp;nbsp; 1 - t + \tau $$" vertex="1">
