        </mxCell>
        <mxCell id="9ZIznnYxpqexiqb3sQ_M-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=21;fontFamily=Lucida Console;fontColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="*" vertex="1">
          <mxGeometry height="17.83" width="21.26" x="438.1" y="113.46" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#80FF00);" value="$$&amp;nbsp; \int_{a}^{b} t^n \space dt&amp;nbsp; =&amp;nbsp; \frac{1}{n + 1} [t^{n+1}]_a^b $$" vertex="1">
          <mxGeometry height="40" width="179.84" x="330.16" y="182.83" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=21;fontFamily=Lucida Console;fontColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="*" vertex="1">
          <mxGeometry height="20" width="20" x="310" y="177" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-3" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
