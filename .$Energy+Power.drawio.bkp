        <mxCell id="VSlh2R8xxgegPrLx676a-24" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1}&amp;nbsp; &amp;nbsp;\leq&amp;nbsp; \int_{0}^{+\infty} e^{-2t} \space dt&amp;nbsp; =&amp;nbsp; -\frac{1}{2} [e^{-2\cdot t}]_0^{+\infty} = -\frac{1}{2} [e^{-2 \cdot {(+\infty)}} - e^0]&amp;nbsp; \Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="37.43" width="340" x="300" y="650.29" as="geometry" />
        </mxCell>
        <mxCell id="VSlh2R8xxgegPrLx676a-25" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1}&amp;nbsp; &amp;nbsp;\leq&amp;nbsp; &amp;nbsp;-\frac{1}{2} [e^{-\infty} - 1]&amp;nbsp; =&amp;nbsp; \frac{1}{2} [ 1 - \frac{1}{e^{+\infty}} ]&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="36.85" width="240" x="380" y="710" as="geometry" />
        </mxCell>
        <mxCell id="VSlh2R8xxgegPrLx676a-26" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1}&amp;nbsp; &amp;nbsp;\leq&amp;nbsp; &amp;nbsp; \frac{1}{2} [ 1 - 0 ]&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="36.85" width="120" x="440" y="770" as="geometry" />
        </mxCell>
        <mxCell id="VSlh2R8xxgegPrLx676a-27" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1}&amp;nbsp; &amp;nbsp;\leq&amp;nbsp; &amp;nbsp; \frac{1}{2}&amp;nbsp; \space \text{Joule} $$" vertex="1">
          <mxGeometry height="36.85" width="100" x="570" y="770" as="geometry" />
        </mxCell>
