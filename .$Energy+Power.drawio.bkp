        <mxCell id="om2gJJYTDZ1tjaiY38PT-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ 0 &amp;lt; \mathcal{E}_x &amp;lt; \infty $$" vertex="1">
          <mxGeometry height="25.12" width="71.8" x="88.31" y="748.01" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_x = \lim_{T&amp;nbsp; \to \infty} \int_{-T}^{T} |x(t)|^2 \space dt $$" vertex="1">
          <mxGeometry height="40" width="143.47" x="211.26" y="703.8000000000001" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ 0 &amp;lt; \mathcal{P}_x &amp;lt; \infty $$" vertex="1">
          <mxGeometry height="25.12" width="71.8" x="83.32" y="875.13" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-4" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \lim_{T&amp;nbsp; \to \infty} \frac{1}{2T} \int_{-T}^{T} |x(t)|^2 \space dt $$" vertex="1">
          <mxGeometry height="40" width="169.5" x="198.24" y="834.29" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-5" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ \text{* Where&amp;nbsp; } T_o \space \rightarrow \space&amp;nbsp; \text{Θεμελιώδης Περίοδος / Fundamental Period}$$" vertex="1">
          <mxGeometry height="25.12" width="358.26" x="231.54000000000002" y="990" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-6" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \frac{1}{T_o} \int_{&amp;lt;T_o&amp;gt;} |x(t)|^2 \space dt $$" vertex="1">
          <mxGeometry height="40" width="151.3" x="198.7" y="912.35" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-7" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \lim_{N&amp;nbsp; \to \infty} \frac{1}{2N + 1} \sum_{n = -N}^{N} |x(n)|^2 $$" vertex="1">
          <mxGeometry height="50" width="190" x="762" y="823.24" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-8" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_x =&amp;nbsp; \sum_{n = - \infty}^{\infty} |x(n)|^2 $$" vertex="1">
          <mxGeometry height="48.42" width="116.98" x="797.26" y="699.5900000000001" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-9" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \frac{1}{N_o} \sum_{n = 0}^{N_o - 1} |x(n)|^2 $$" vertex="1">
          <mxGeometry height="50" width="133.53" x="789.3399999999999" y="907.3499999999999" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-10" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ \text{When&amp;nbsp; } x(t) \in \mathbb{R} \space \Rightarrow \space&amp;nbsp; |x(t)|^2 = x(t) \cdot x(t) = x^2(t)$$" vertex="1">
          <mxGeometry height="25.12" width="272.38" x="252.79000000000002" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-11" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ \text{When&amp;nbsp; } x(t) \in \mathbb{C} \space \Rightarrow \space&amp;nbsp; |x(t)|^2 = x(t) \cdot x^*(t) $$" vertex="1">
          <mxGeometry height="25.12" width="236.06" x="251.25000000000006" y="1065.32" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-13" parent="1" style="shape=partialRectangle;whiteSpace=wrap;html=1;bottom=1;right=1;left=1;top=0;fillColor=none;routingCenterX=-0.5;rotation=270;strokeColor=light-dark(#000000,#FFCC99);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="15.8" width="108.4" x="542.49" y="1034.6599999999999" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-14" parent="1" style="shape=partialRectangle;whiteSpace=wrap;html=1;bottom=1;right=1;left=1;top=0;fillColor=none;routingCenterX=-0.5;rotation=270;flipV=1;legacyAnchorPoints=0;strokeColor=light-dark(#000000,#FFCC99);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="15.8" width="108.4" x="166.12000000000012" y="1034.6599999999999" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-15" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \frac{1}{T_o} \int_{&amp;lt;T_o&amp;gt;} |x(t)|^2 \space dt \equiv \frac{1}{T_o} \int_{0}^{T_o} |x(t)|^2 \space dt&amp;nbsp; \equiv&amp;nbsp;&amp;nbsp;\frac{1}{T_o} \int_{T_o}^{2T_o} |x(t)|^2 \space dt \equiv \frac{1}{T_o} \int_{nT_o}^{(n+1)T_o} |x(t)|^2 dt$$" vertex="1">
          <mxGeometry height="59.77" width="520" x="71.13" y="1130" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-16" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Also:" vertex="1">
          <mxGeometry height="18.8" width="40" x="-30" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-17" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \frac{1}{T_o} \int_{&amp;lt;T_o&amp;gt;} |x(t)|^2 \space dt \equiv \frac{1}{T_o} \int_{-T_o / 2}^{T_o / 2} |x(t)|^2 \space dt $$" vertex="1">
          <mxGeometry height="59.77" width="288.28" x="62.33" y="1199.52" as="geometry" />
        </mxCell>
        <mxCell id="om2gJJYTDZ1tjaiY38PT-18" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="and:" vertex="1">
