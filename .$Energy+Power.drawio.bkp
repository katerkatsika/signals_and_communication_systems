        </mxCell>
        <mxCell id="8Teos5xmoUq133Y0zAmz-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Calculate the mean power of the following signal:&amp;nbsp;" vertex="1">
          <mxGeometry height="30" width="248.9" x="-280.28" y="-35" as="geometry" />
        </mxCell>
        <mxCell id="2I7ADo8gNN3zLt6Iux9f-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ x(t) = A_1 \space cos \space (\omega_1 \space t + \theta_1) +&amp;nbsp; A_2 \space cos \space (\omega_2 \space t + \theta_2)$$" vertex="1">
          <mxGeometry height="30" width="270" x="-249" y="10" as="geometry" />
        </mxCell>
        <mxCell id="2I7ADo8gNN3zLt6Iux9f-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="in the general case where:" vertex="1">
          <mxGeometry height="30" width="134" x="-281" y="54" as="geometry" />
        </mxCell>
        <mxCell id="2I7ADo8gNN3zLt6Iux9f-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ \omega_1 \neq \omega_2 $$" vertex="1">
          <mxGeometry height="30" width="60" x="-141" y="53" as="geometry" />
        </mxCell>
        <mxCell id="mFNMFGRKmDqplvmoimxY-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Solution" vertex="1">
          <mxGeometry height="20" width="45" x="-280" y="120" as="geometry" />
        </mxCell>
        <mxCell id="mFNMFGRKmDqplvmoimxY-2" edge="1" parent="1" style="edgeStyle=none;orthogonalLoop=1;jettySize=auto;html=1;rounded=0;endArrow=none;endFill=0;strokeColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="">
          <mxGeometry relative="1" width="80" as="geometry">
            <Array as="points" />
            <mxPoint x="-279.98" y="144" as="sourcePoint" />
            <mxPoint x="560" y="144" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="mFNMFGRKmDqplvmoimxY-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#00FFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ x(t) =&amp;nbsp; \sum_{n = 1}^{ \infty }A_n \space cos \space (\omega_n \space t + \theta_n) $$" vertex="1">
          <mxGeometry height="50" width="185.58" x="-147" y="1610" as="geometry" />
        </mxCell>
        <mxCell id="mFNMFGRKmDqplvmoimxY-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Lucida Console;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="We do not know whether the sum of these two periodic signals is also&amp;nbsp; periodic (as we don&#39;t know whether the ratio ω&lt;sub&gt;1&lt;/sub&gt; / ω&lt;sub&gt;2&lt;/sub&gt; is rational).&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;div&gt;So, in order to calculate the mean power of the signal we have to take the formula for the general case of a non-periodic signal where we integrate over a time interval T with T going to infinity.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="530" x="-280" y="160" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \lim_{T&amp;nbsp; \to \infty} \frac{1}{T} \int_{-T/2}^{+T/2} |x(t)|^2 \space dt \space \Rightarrow \\ \\ \mathcal{P}_x = \lim_{T&amp;nbsp; \to \infty} \frac{1}{T} \int_{-T/2}^{+T/2} [ A_1 \cdot cos(\omega_1 \cdot t&amp;nbsp; +&amp;nbsp; \theta_1)&amp;nbsp; &amp;nbsp;+&amp;nbsp; A_2 \cdot cos(\omega_2 \cdot t&amp;nbsp; +&amp;nbsp; \theta_2)&amp;nbsp;]^2&amp;nbsp; \space dt \space&amp;nbsp; \Rightarrow&amp;nbsp; \\ \\&amp;nbsp; \mathcal{P}_x =&amp;nbsp;\lim_{T&amp;nbsp; \to \infty} \frac{A^2_1}{T} \int_{-T/2}^{+T/2}&amp;nbsp; &amp;nbsp; cos^2 (\omega_1 \cdot t&amp;nbsp; +&amp;nbsp; \theta_1) \space dt&amp;nbsp; &amp;nbsp; + \lim_{T&amp;nbsp; \to \infty} \frac{A^2_2}{T} \int_{-T/2}^{+T/2}&amp;nbsp; &amp;nbsp; cos^2 (\omega_2 \cdot t&amp;nbsp; +&amp;nbsp; \theta_2) \space dt&amp;nbsp; &amp;nbsp; +&amp;nbsp; \lim_{T&amp;nbsp; \to \infty} \frac{2 A_1 A_2}{T} \int_{-T/2}^{+T/2} cos (\omega_1 \cdot t + \theta_1) \cdot cos (\omega_2 \cdot t + \theta_2) \space dt&amp;nbsp;&amp;nbsp;$$" vertex="1">
          <mxGeometry height="180" width="773" x="-273" y="260" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-2" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;rotation=270;strokeColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="190" width="20" x="-152.35" y="345" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-3" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;rotation=270;strokeColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="190" width="20" x="65" y="345" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-4" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;rotation=270;strokeColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="305" width="20" x="330.5" y="287.5" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ P_{x_1} $$" vertex="1">
          <mxGeometry height="30" width="30" x="-157.35" y="460" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ P_{x_2} $$" vertex="1">
          <mxGeometry height="30" width="30" x="60" y="460" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ P_{x_3} $$" vertex="1">
          <mxGeometry height="30" width="30" x="325.5" y="460" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ P_x = P_{x_1} + P_{x_2} + P_{x_3}&amp;nbsp;$$" vertex="1">
          <mxGeometry height="30" width="149" x="0.5" y="530" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-9" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=12;" value="" vertex="1">
          <mxGeometry height="60" width="166.5" x="-8.25" y="515" as="geometry" />
        </mxCell>
        <mxCell id="nUx0hvGLIuTmPP1rv-mG-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Lucida Console;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="In Exercise 1, we have calculated the first two integrals trying to find the power of a simple cosine signal:" vertex="1">
          <mxGeometry height="30" width="510.28" x="-280.28" y="600" as="geometry" />
        </mxCell>
        <mxCell id="GpNdAEtC3-1E9fl_x-SL-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFFFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ P_{x_1} = \frac{A_1^2}{2}$$" vertex="1">
          <mxGeometry height="40" width="65" x="-158.67" y="785" as="geometry" />
        </mxCell>
        <mxCell id="GpNdAEtC3-1E9fl_x-SL-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFFFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ P_{x_2} = \frac{A_2^2}{2}$$" vertex="1">
          <mxGeometry height="40" width="65" x="-46.32" y="785" as="geometry" />
        </mxCell>
        <mxCell id="GpNdAEtC3-1E9fl_x-SL-3" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=13;" value="" vertex="1">
          <mxGeometry height="50" width="81" x="-166.67" y="780" as="geometry" />
        </mxCell>
        <mxCell id="GpNdAEtC3-1E9fl_x-SL-4" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#FFFF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=13;" value="" vertex="1">
          <mxGeometry height="50" width="81" x="-54.32" y="780" as="geometry" />
        </mxCell>
        <mxCell id="GpNdAEtC3-1E9fl_x-SL-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Lucida Console;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Need to calculate the 3rd integral. So we have:&amp;nbsp;" vertex="1">
          <mxGeometry height="30" width="230" x="-280" y="905" as="geometry" />
        </mxCell>
        <mxCell id="GpNdAEtC3-1E9fl_x-SL-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFFFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ 2 \cdot&amp;nbsp; &amp;nbsp;cos \space (\omega_1 \space t + \theta_1) \cdot&amp;nbsp; cos \space (\omega_2 \space t + \theta_2)&amp;nbsp; =&amp;nbsp; &amp;nbsp;cos [(\omega_1 \space t + \theta_1) + (\omega_2 \space t + \theta_2) ]&amp;nbsp; + cos [(\omega_1 \space t + \theta_1) - (\omega_2 \space t + \theta_2) ]&amp;nbsp;$$" vertex="1">
          <mxGeometry height="30" width="564.85" x="-244.85" y="950" as="geometry" />
        </mxCell>
        <mxCell id="f9bBm7ZDhf-VZOYNuRwz-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$ \mathcal{P_x}&amp;nbsp; &amp;nbsp;=&amp;nbsp; &amp;nbsp; \lim_{T&amp;nbsp; \to \infty} \frac{1}{T_o} \int_{-T_ο /2}^{T_ο /2} A^2 \cdot cos^2 (2 \pi f_o t) \space dt \space = \frac{A^2}{2} $$" vertex="1">
          <mxGeometry height="53.59" width="278.85" x="-197.43" y="670" as="geometry" />
        </mxCell>
        <mxCell id="LtFkH3tGeJRi3oHKgOUD-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFFFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ x(t) = A \space cos \space (2 \pi f \space t) $$" vertex="1">
          <mxGeometry height="30" width="120" x="-118" y="630" as="geometry" />
        </mxCell>
        <mxCell id="LtFkH3tGeJRi3oHKgOUD-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Lucida Console;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Similarly, since the presence of a non-zero phase does not change the result, we have:" vertex="1">
          <mxGeometry height="30" width="420" x="-280" y="740" as="geometry" />
        </mxCell>
        <mxCell id="su_xj6z95fuZYxqRTjXm-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Lucida Console;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Because:" vertex="1">
          <mxGeometry height="30" width="46.32" x="-279.32" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="su_xj6z95fuZYxqRTjXm-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFFFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ 2 \cdot&amp;nbsp; &amp;nbsp;cos \space (\phi_1) \cdot&amp;nbsp; cos \space (\phi_2)&amp;nbsp; =&amp;nbsp; &amp;nbsp;cos ( \phi_1 + \phi_2) &amp;nbsp;+ cos (\phi_1 - \phi_2)&amp;nbsp; $$" vertex="1">
          <mxGeometry height="30" width="304.85" x="-210.42" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="su_xj6z95fuZYxqRTjXm-3" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=light-dark(#000000,#FFFFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=13;" value="&lt;span style=&quot;font-family: &amp;quot;Lucida Console&amp;quot;; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(27, 29, 30); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;$$ P_{x_3} = \lim_{T \to \infty} \frac{2 A_1 A_2}{T} \int_{-T/2}^{+T/2} cos (\omega_1 \cdot t + \theta_1) \cdot cos (\omega_2 \cdot t + \theta_2) \space dt&amp;nbsp; \Rightarrow $$&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="370.14" x="-210.14" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="su_xj6z95fuZYxqRTjXm-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Lucida Console;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Therefore:" vertex="1">
          <mxGeometry height="30" width="60" x="-279" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="su_xj6z95fuZYxqRTjXm-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=13;" value="$$ P_{x_3}&amp;nbsp; =&amp;nbsp; \lim_{T \to \infty} \frac{2 A_1 A_2}{T} \int_{-T/2}^{+T/2} cos[(\omega_1 \space t + \theta_1) + \omega_2 \space t + \theta_2)&amp;nbsp;] \space dr&amp;nbsp; &amp;nbsp;+&amp;nbsp; \lim_{T \to \infty} \frac{2 A_1 A_2}{T} \int_{-T/2}^{+T/2} cos[(\omega_1 \space t + \theta_1) - \omega_2 \space t + \theta_2) ] \space dr&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="50" width="755" x="-265" y="1170" as="geometry" />
        </mxCell>
