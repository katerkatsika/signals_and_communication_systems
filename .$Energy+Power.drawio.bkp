        <mxCell id="IDfcM6hOCJMViYuoumf8-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Solution" vertex="1">
          <mxGeometry height="20" width="45" x="-360" y="70" as="geometry" />
        </mxCell>
        <mxCell id="IDfcM6hOCJMViYuoumf8-2" edge="1" parent="1" style="edgeStyle=none;orthogonalLoop=1;jettySize=auto;html=1;rounded=0;endArrow=none;endFill=0;strokeColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="">
          <mxGeometry relative="1" width="80" as="geometry">
            <Array as="points" />
            <mxPoint x="-359.98" y="94" as="sourcePoint" />
            <mxPoint x="160" y="94" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IDfcM6hOCJMViYuoumf8-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_x = \frac{1}{2a} [e^{2at}]_{-\infty}^{+\infty}&amp;nbsp; =&amp;nbsp; \frac{1}{2a} [ e^{2a \cdot (+\infty)} - e^{2a \cdot (-\infty)}&amp;nbsp; ]&amp;nbsp;\Rightarrow $$" vertex="1">
          <mxGeometry height="50" width="312.52" x="-302.34999999999997" y="190" as="geometry" />
        </mxCell>
        <mxCell id="IDfcM6hOCJMViYuoumf8-4" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_x =&amp;nbsp; \frac{1}{2a} [ e^{ +\infty} - e^{&amp;nbsp; -\infty}&amp;nbsp; ]&amp;nbsp; =&amp;nbsp;&amp;nbsp;&amp;nbsp;\frac{1}{2a}&amp;nbsp; [e^{ +\infty}&amp;nbsp; -&amp;nbsp; \frac{1}{e^{ +\infty}}]&amp;nbsp; \Rightarrow $$" vertex="1">
