        <mxCell id="4CiS7-30Nb2y2kFoCpzf-4" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1} =&amp;nbsp; &amp;nbsp;\frac{1}{4} [ e^0 - \frac{1}{e^{ \infty}}&amp;nbsp; ] =&amp;nbsp;&amp;nbsp;\frac{1}{4} [ 1 - 0]&amp;nbsp;&amp;nbsp;&amp;nbsp; \Rightarrow&amp;nbsp; $$" vertex="1">
