        <mxCell id="E_Ctf5GzWvUAYLiA3ufi-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="First, we calculate the energy of this signal and we&amp;nbsp;check if it is finite:" vertex="1">
          <mxGeometry height="18.8" width="340" x="181" y="277" as="geometry" />
        </mxCell>
        <mxCell id="E_Ctf5GzWvUAYLiA3ufi-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="Therefore, the given signal is NOT an energy signal." vertex="1">
          <mxGeometry height="18.8" width="261.13" x="634.8599999999999" y="689.6" as="geometry" />
        </mxCell>
        <mxCell id="hVy5cTOxkz3sDbbQm_Pu-1" parent="1" style="shape=waypoint;sketch=0;fillStyle=solid;size=6;pointerEvents=1;points=[];fillColor=none;resizable=0;rotatable=0;perimeter=centerPerimeter;snapToPoint=1;strokeWidth=2;strokeColor=light-dark(#000000,#FFFF00);movable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="20" width="20" x="156.63" y="276.40000000000003" as="geometry" />
        </mxCell>
        <mxCell id="hVy5cTOxkz3sDbbQm_Pu-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ \mathcal{P}_x &amp;lt; \infty $$" vertex="1">
          <mxGeometry height="25.12" width="58.9" x="323.2700000000001" y="801" as="geometry" />
        </mxCell>
        <mxCell id="hVy5cTOxkz3sDbbQm_Pu-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Then, we calculate the power of this signal and we&amp;nbsp;check if it is finite:" vertex="1">
          <mxGeometry height="18.8" width="367.28" x="182.72" y="781.6" as="geometry" />
        </mxCell>
        <mxCell id="hVy5cTOxkz3sDbbQm_Pu-4" parent="1" style="shape=waypoint;sketch=0;fillStyle=solid;size=6;pointerEvents=1;points=[];fillColor=none;resizable=0;rotatable=0;perimeter=centerPerimeter;snapToPoint=1;strokeWidth=2;strokeColor=light-dark(#000000,#FFFF00);movable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="20" width="20" x="158.35" y="781" as="geometry" />
        </mxCell>
        <mxCell id="Nsz5vsrUDT5Mad_n7VAv-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x =&amp;nbsp; \lim_{T_o&amp;nbsp; \to \infty} \frac{1}{T_o}&amp;nbsp;\int_{-T_o / 2}^{T_o / 2} |A \cdot cos \space (2 \pi f_o t)|^2 \space dt =&amp;nbsp;&amp;nbsp;\lim_{T_o&amp;nbsp; \to \infty} \frac{1}{T_o} \int_{-T_ο /2}^{T_ο /2} A^2 \cdot cos^2 (2 \pi f_o t) \space dt \space = \space \lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{T_o}&amp;nbsp;\int_{-T_o /2}^{T_o /2}&amp;nbsp; \frac{1}{2} [1 + cos \space (2 \cdot 2 \pi f_o t)] \space dt \Rightarrow $$" vertex="1">
          <mxGeometry height="53.59" width="716.95" x="269.92" y="900" as="geometry" />
        </mxCell>
        <mxCell id="nllUbzvREs8Y6xl3lX8V-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \lim_{T_0&amp;nbsp; \to \infty} \frac{1}{T_o} \int_{-T_o /2}^{T_o /2} |x(t)|^2 \space dt&amp;nbsp; \Rightarrow$$" vertex="1">
          <mxGeometry height="45" width="212.7" x="242.68" y="845" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=21;fontFamily=Lucida Console;fontColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="*" vertex="1">
          <mxGeometry height="17.83" width="21.26" x="715" y="912" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x =&amp;nbsp; &amp;nbsp;\lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{2 T_o} [ \int_{-T_o /2}^{T_o /2}&amp;nbsp; 1 \space dt + \int_{-T_o /2}^{T_o /2}&amp;nbsp;cos \space (4 \pi f_o t) \space dt]&amp;nbsp; =&amp;nbsp;&amp;nbsp;&amp;nbsp;\lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{2 T_o} [ t + \frac{1}{4 \pi f_o} \cdot sin(4 \pi f_o t)]_{-T_o /2}^{T_o /2}&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="53.59" width="541.73" x="294.08" y="970" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-5" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x =&amp;nbsp; &amp;nbsp; \lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{2 T_o} [ \frac{T_o}{2} -&amp;nbsp; (\frac{-T_o}{2}) + \frac{1}{4 \pi f_o} \cdot sin(4 \pi f_o \frac{T_o}{2}) - \frac{1}{4 \pi f_o} \cdot sin(- 4 \pi f_o \frac{T_o}{2})&amp;nbsp;]&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="43.59" width="476.73" x="332.43" y="1047" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-6" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x =&amp;nbsp; &amp;nbsp; \lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{2 T_o} [ \frac{T_o}{2} + (\frac{T_o}{2}) + \frac{1}{4 \pi f_o} \cdot sin(2 \pi f_o T_o) - \frac{1}{4 \pi f_o} \cdot sin(- 2 \pi f_o T_o)&amp;nbsp;]&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="43.59" width="457.83" x="382.17" y="1110" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=21;fontFamily=Lucida Console;fontColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="**" vertex="1">
          <mxGeometry height="17.83" width="30" x="820" y="1114" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=21;fontFamily=Lucida Console;fontColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="**" vertex="1">
          <mxGeometry height="17.83" width="30" x="470" y="1177" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-10" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#80FF00);" value="$$&amp;nbsp; f_o = \frac{1}{T_o} \Rightarrow f_o \cdot T_o = 1 $$" vertex="1">
          <mxGeometry height="40" width="140" x="509.29" y="1179.61" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-11" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="40.7" width="158.57" x="500" y="1178.91" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-13" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x =&amp;nbsp; &amp;nbsp; \lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{2 T_o} [ T_o + \frac{1}{4 \pi f_o} \cdot sin(2 \pi) - \frac{1}{4 \pi f_o} \cdot sin(- 2 \pi)&amp;nbsp;]&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="43.59" width="347.83" x="530" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=21;fontFamily=Lucida Console;fontColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="***" vertex="1">
          <mxGeometry height="17.83" width="30" x="860" y="1253" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-15" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=21;fontFamily=Lucida Console;fontColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="***" vertex="1">
          <mxGeometry height="17.83" width="30" x="461" y="1323" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-16" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#80FF00);" value="$$&amp;nbsp; sin\space&amp;nbsp; (k 2 \pi) = 0 \space \text{ for } \space k \in \mathbb{Z} $$" vertex="1">
          <mxGeometry height="40" width="150" x="500.57" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-17" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#80FF00);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="30" width="158.57" x="497.57" y="1325" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-20" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x =&amp;nbsp; &amp;nbsp; \lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{2 \space&amp;nbsp; T_o} [T_o]&amp;nbsp; \Rightarrow&amp;nbsp; \mathcal{P}_x =&amp;nbsp; &amp;nbsp; \lim_{T_o&amp;nbsp; \to \infty} \frac{A^2}{2}&amp;nbsp; \space&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="43.59" width="268.49" x="600" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-21" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="$$&amp;nbsp; \mathcal{P}_x =&amp;nbsp; \frac{A^2}{2} \space \text{ [Watt]} $$" vertex="1">
          <mxGeometry height="43.59" width="118" x="872" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-22" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#00FFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="50" width="130" x="866" y="1376.8" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-23" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="the given signal IS a power signal." vertex="1">
