          </mxGeometry>
        </mxCell>
        <mxCell id="ZHhtosTQEzOQiIxzj41V-6" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1} = \frac{4}{3} \space \text{ [Joules] }$$" vertex="1">
          <mxGeometry height="46.85" width="126.74" x="593.26" y="105" as="geometry" />
        </mxCell>
        <mxCell id="ZHhtosTQEzOQiIxzj41V-7" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#00FFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
