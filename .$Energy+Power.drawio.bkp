          <mxGeometry height="40" width="159.33" x="392" y="454.3" as="geometry" />
        </mxCell>
        <mxCell id="UG2G2s75xn-w1sXVM5mk-6" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_x = \lim_{T&amp;nbsp; \to \infty} \int_{-T}^{T} |A \cdot cos \space (2 \pi f)|^2 \space dt =&amp;nbsp;&amp;nbsp;\lim_{T&amp;nbsp; \to \infty} \int_{-T}^{T} A^2 \cdot cos^2 (2 \pi f) \space dt \space = \space \lim_{T&amp;nbsp; \to \infty} \int_{-T}^{T}&amp;nbsp;A^2&amp;nbsp;\frac{1}{2} [1 + cos \space (2 \cdot 2 \pi f)] \space dt \Rightarrow $$" vertex="1">
          <mxGeometry height="53.59" width="592.15" x="207.30000000000004" y="392.12" as="geometry" />
        </mxCell>
        <mxCell id="UG2G2s75xn-w1sXVM5mk-7" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_x = \lim_{T&amp;nbsp; \to \infty} \frac{A^2}{2} \int_{-T}^{T} [ 1 + cos \space (4 \pi f \space t)] \space dt =&amp;nbsp;&amp;nbsp;\lim_{T&amp;nbsp; \to \infty}&amp;nbsp;&amp;nbsp;\frac{A^2}{2} [ \int_{-T}^{T} 1 \cdot dt +&amp;nbsp;&amp;nbsp;\int_{-T}^{T} cos \space (4 \pi f \space t) \space dt] \Rightarrow $$" vertex="1">
