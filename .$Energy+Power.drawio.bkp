        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-24" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="$$ \mathcal{P}_x &amp;lt; \infty $$" vertex="1">
          <mxGeometry height="25.12" width="58.9" x="845" y="1456.84" as="geometry" />
        </mxCell>
        <mxCell id="_jLuwTUtsV6lF5p9SzgX-25" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="So since:" vertex="1">
          <mxGeometry height="18.8" width="60" x="780" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="xyFkHwBOxp4DNnHM3Zjy-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=12;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFF00);" value="Note: The power of a signal depends only on its amplitude, not other of its features like frequency and phase." vertex="1">
