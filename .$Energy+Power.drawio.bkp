        <mxCell id="om2gJJYTDZ1tjaiY38PT-19" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P}_x = \frac{1}{T_o} \int_{&amp;lt;T_o&amp;gt;} |x(t)|^2 \space dt \equiv \frac{1}{2T_o} \int_{-T_o}^{T_o} |x(t)|^2 \space dt&amp;nbsp; $$" vertex="1">
