        <mxCell id="5LfoKptMpbQkWaf6CpJz-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1} = \lim_{T&amp;nbsp; \to \infty} \int_{-T}^{T} |x_1(t)|^2 \space dt =&amp;nbsp; \int_{-\infty}^{+\infty} |x_1(t)|^2 \space dt&amp;nbsp;&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="281.64" x="35.82" y="8680" as="geometry" />
