        <mxCell id="T4tig9nSS4AWSmA_x5d1-4" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_2} = \lim_{T&amp;nbsp; \to \infty} \int_{-T}^{T} |x_2(t)|^2 \space dt =&amp;nbsp; \int_{-\infty}^{+\infty} |x_2(t)|^2 \space dt&amp;nbsp;&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="327.02" x="242.94" y="539.42" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-5" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_2} =&amp;nbsp; \int_{-1}^{0} (2 \space t + 2)^2 \space dt = \int_{-1}^{0} 2^2 \space (t + 1)^2 \space dt&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="308.64" x="291.36" y="610.09" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-6" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_2} =&amp;nbsp; 4 \int_{-1}^{0}&amp;nbsp; \space (t + 1)^2 \space dt&amp;nbsp; =&amp;nbsp; 4 \int_{-1}^{0}&amp;nbsp; \space (t + 1)^2 \space d(t + 1)&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="345.1" x="354.9" y="683.46" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-7" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_2} =&amp;nbsp; \frac{4}{3} [(t + 1)^3]_0^1 =&amp;nbsp;&amp;nbsp;\frac{4}{3} [(0 + 1)^3 - (1 -1)^3]&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="345.1" x="401.31" y="763.12" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-8" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_2} =&amp;nbsp; \frac{4}{3} \space \text{ [Joules]} $$" vertex="1">
          <mxGeometry height="45.79" width="121" x="760" y="768.6500000000001" as="geometry" />
        </mxCell>
        <mxCell id="T4tig9nSS4AWSmA_x5d1-9" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#000000,#00FFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
