          <mxGeometry height="30" width="85.95" x="-295.95" y="-18.31" as="geometry" />
        </mxCell>
        <mxCell id="iY7MVxwlBp64Z9mc1yTv-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=12;fontFamily=Lucida Console;fontColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="calculate its energy and determine if it is an energy&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 242, 204));&quot;&gt;signal.&lt;/span&gt;" vertex="1">
