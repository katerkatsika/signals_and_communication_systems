        <mxCell id="m21LxcbFHnWtogkh_7TT-9" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_2} =&amp;nbsp; \int_{-\infty}^{0} 0^2 \space dt&amp;nbsp; +&amp;nbsp;&amp;nbsp;\int_{0}^{1} 1^2 \space dt&amp;nbsp; + \int_{1}^{+ \infty} 0^2 \space dt&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
