        <mxCell id="Nv-8DoyOTOQttvyC_Hcq-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;fontColor=light-dark(#000000,#FFFFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ P_x = P_{x_1} + P_{x_2} + P_{x_3}&amp;nbsp; \Rightarrow \\&amp;nbsp; \\P_x = \frac{A_1^2}{2} + \frac{A_2^2}{2}&amp;nbsp; + 0 \Rightarrow \\&amp;nbsp; \\ P_x = \frac{1}{2} \cdot (A_1^2 + A_2^2) $$" vertex="1">
