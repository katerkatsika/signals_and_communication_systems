        <mxCell id="7Av0Fn65pJK0dxpOJTiD-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P_x} =&amp;nbsp; \frac{1}{1} \int_{0}^{1} (e^{-t})^2 \space dt&amp;nbsp; =&amp;nbsp; \int_{0}^{1} e^{-2t} \space dt&amp;nbsp;&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="49.77" width="228.2" x="-128.2" y="279" as="geometry" />
        </mxCell>
        <mxCell id="7Av0Fn65pJK0dxpOJTiD-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P_x}&amp;nbsp; &amp;nbsp;=&amp;nbsp; - \frac{1}{2} [e^{-2t}]_0^1&amp;nbsp; =&amp;nbsp; - \frac{1}{2} \cdot [ e^{-2 \cdot 1} - e^{-2 \cdot 0}]&amp;nbsp; \Rightarrow $$" vertex="1">
          <mxGeometry height="49.77" width="240" x="-100" y="339" as="geometry" />
        </mxCell>
        <mxCell id="7Av0Fn65pJK0dxpOJTiD-4" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P_x}&amp;nbsp; &amp;nbsp;= -&amp;nbsp; \frac{1}{2} \cdot [ e^{-2 } - e^{ 0}]&amp;nbsp; =&amp;nbsp; \frac{1}{2} \cdot [ e^{ 0} - e^{-2 }&amp;nbsp;&amp;nbsp;]&amp;nbsp;\Rightarrow $$" vertex="1">
          <mxGeometry height="49.77" width="240" x="-66.46000000000001" y="399" as="geometry" />
        </mxCell>
        <mxCell id="7Av0Fn65pJK0dxpOJTiD-5" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{P_x}&amp;nbsp; &amp;nbsp;=&amp;nbsp; \frac{1}{2} \cdot [ 1 - \frac{1}{e^2} ]&amp;nbsp; &amp;nbsp;=&amp;nbsp; \frac{1}{2} \cdot [ 1 - 0.135 ]&amp;nbsp;\Rightarrow $$" vertex="1">
          <mxGeometry height="49.77" width="240" x="-26.23" y="459" as="geometry" />
        </mxCell>
        <mxCell id="7Av0Fn65pJK0dxpOJTiD-6" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#00FFFF);" value="$$&amp;nbsp; \mathcal{P_x}&amp;nbsp; &amp;nbsp;\approx&amp;nbsp; 0.432 \space \text{ Watt}$$" vertex="1">
          <mxGeometry height="29.77" width="110.63" x="229.37" y="469" as="geometry" />
        </mxCell>
