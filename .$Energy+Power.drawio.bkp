        </mxCell>
        <mxCell id="DulgcvBEPoiu7KfJud2x-17" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="Οπότε:" vertex="1">
          <mxGeometry height="30" width="50" x="203.60999999999999" y="464.78" as="geometry" />
        </mxCell>
        <mxCell id="ZHhtosTQEzOQiIxzj41V-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1} = \lim_{T&amp;nbsp; \to \infty} \int_{-T}^{T} |x_1(t)|^2 \space dt =&amp;nbsp; \int_{-\infty}^{+\infty} |x_1(t)|^2 \space dt&amp;nbsp;&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="327.02" x="232.98" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="ZHhtosTQEzOQiIxzj41V-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1} =&amp;nbsp; \int_{0}^{1} (2 \space t)^2 \space dt = 4 \int_{0}^{1}&amp;nbsp;t^2 \space dt&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="236.89" x="295.2" y="30" as="geometry" />
        </mxCell>
        <mxCell id="ZHhtosTQEzOQiIxzj41V-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFFFFF);" value="$$&amp;nbsp; \mathcal{E}_{x_1} = 4 \cdot \frac{1}{3} [t^3]_0^1&amp;nbsp; = 4 \cdot \frac{1}{3} [1^3 - 0^3]&amp;nbsp;&amp;nbsp;\Rightarrow&amp;nbsp; $$" vertex="1">
          <mxGeometry height="56.85" width="236.89" x="333.07" y="100" as="geometry" />
        </mxCell>
        <mxCell id="ZHhtosTQEzOQiIxzj41V-4" edge="1" parent="1" style="edgeStyle=none;orthogonalLoop=1;jettySize=auto;html=1;rounded=0;endArrow=none;endFill=0;strokeColor=light-dark(#000000,#FFF2CC);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="">
