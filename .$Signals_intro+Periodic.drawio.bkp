        <mxCell id="64nvRaoDaBRu7dWff4kt-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=13;" value="$$&amp;nbsp; \omega_1 = \frac{1}{2} \Rightarrow \space \frac{2 \pi}{T_1} = \frac{1}{2} \Rightarrow \space T_1 = \frac{2 \pi}{1/2} \Rightarrow \space T_1 = 4 \pi $$" vertex="1">
