          <mxGeometry height="32" width="40" x="517.92" y="375" as="geometry" />
        </mxCell>
        <mxCell id="rPaCh1XliGgk2pr5-XB_-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFF2CC);" value="b) Τα σήματα y&lt;sub&gt;1&lt;/sub&gt;(t), y&lt;sub&gt;2&lt;/sub&gt;(t) και y&lt;sub&gt;3&lt;/sub&gt;(t) έχουν περιόδους 1.08 s, 3.6 s και 2.025 s αντίστοιχα." vertex="1">
          <mxGeometry height="20" width="529.52" x="119.38999999999999" y="414" as="geometry" />
        </mxCell>
        <mxCell id="rPaCh1XliGgk2pr5-XB_-4" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=13;fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;fontColor=light-dark(#000000,#FFF2CC);" value="Να εξεταστεί εάν τα σήματα x&lt;sub&gt;1&lt;/sub&gt;(t) + x&lt;sub&gt;2&lt;/sub&gt;(t) + x&lt;sub&gt;3&lt;/sub&gt;(t) καθώς και y&lt;sub&gt;1&lt;/sub&gt;(t) + y&lt;sub&gt;2&lt;/sub&gt;(t) + y&lt;sub&gt;3&lt;/sub&gt;(t) είναι&lt;div&gt;περιοδικά και αν ναι, να βρεθεί η θεμελιώδης περίοδος και η θεμελιώδης συχνότητά τους.&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="570" x="122" y="434" as="geometry" />
        </mxCell>
        <mxCell id="rPaCh1XliGgk2pr5-XB_-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="(a)" vertex="1">
          <mxGeometry height="30" width="30" x="118.39" y="530" as="geometry" />
        </mxCell>
        <mxCell id="FYDRxP7-SQNLzNOulM3Q-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=13;" value="$$ \frac{T_1}{T_2} = \frac{8/3}{1.26} = \frac{8}{3.76} = \frac{800}{376} \space \rightarrow \space \text{rational / ρητός}$$" vertex="1">
